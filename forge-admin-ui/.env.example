# 环境变量配置示例

# 应用标题
VITE_TITLE=Forge Admin

# API基础路径
VITE_API_BASE_URL=/

# 公共路径
VITE_PUBLIC_PATH=/

# 是否使用hash路由
VITE_USE_HASH=false

# 首页路径
VITE_HOME_PATH=/home

# 客户端配置（新增）
# 客户端AppId
VITE_APP_ID=forge_pc_001

# 客户端AppSecret（可选，启用客户端验证时需要）
# 注意：生产环境建议使用更安全的方式管理密钥，不要直接写在这里
# VITE_APP_SECRET=your_app_secret_here
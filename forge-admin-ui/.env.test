# 静态资源目录
PUBLIC_PATH=/prod-web

# 路由前缀
BASE_URL=/prod-web

O_AUTH_PREFIX=/

OUTPUT=dist

# 请求地址前缀
REQUEST_PREFIX=/prod-server

SYS_PREFIX=/prod-server

# map文件
DEVTOOL=none

# 生产环境代理地址
HTTP_PROXY_TARGET=http://127.0.0.1:11100/

#SYS_PREFIX=''

# 图片host地址
ZIP_NAME=dist
RESOURCE_HOST=/

# 下载文件请求接口前缀
DOWNLOAD_FILE_PREFIX=/prod-server

TEMPLATE_PATH=/prod-web/templates

# 下载文件请求接口前缀
DOWNLOAD_FILE_PREFIX=/prod-server

MODE=hash


#MODE=history

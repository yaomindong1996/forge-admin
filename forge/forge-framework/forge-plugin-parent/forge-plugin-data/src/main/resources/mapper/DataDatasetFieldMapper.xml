<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mdframe.forge.plugin.data.mapper.DataDatasetFieldMapper">

    <resultMap id="BaseResultMap" type="com.mdframe.forge.plugin.data.entity.DataDatasetField">
        <id column="id" property="id"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="dataset_id" property="datasetId"/>
        <result column="field_name" property="fieldName"/>
        <result column="field_label" property="fieldLabel"/>
        <result column="source_column" property="sourceColumn"/>
        <result column="db_type" property="dbType"/>
        <result column="data_type" property="dataType"/>
        <result column="field_role" property="fieldRole"/>
        <result column="default_agg" property="defaultAgg"/>
        <result column="query_enabled" property="queryEnabled"/>
        <result column="display_enabled" property="displayEnabled"/>
        <result column="sensitive_level" property="sensitiveLevel"/>
        <result column="mask_rule" property="maskRule"/>
        <result column="dict_type" property="dictType"/>
        <result column="sort" property="sort"/>
        <result column="description" property="description"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="create_dept" property="createDept"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectFieldListByDatasetId" resultMap="BaseResultMap">
        SELECT *
        FROM ai_report_data_dataset_field
        WHERE dataset_id = #{datasetId}
          AND tenant_id = #{tenantId}
        ORDER BY sort ASC, id ASC
    </select>

    <delete id="deleteByDatasetId">
        DELETE FROM ai_report_data_dataset_field
        WHERE dataset_id = #{datasetId}
          AND tenant_id = #{tenantId}
    </delete>

</mapper>
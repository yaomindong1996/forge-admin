<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mdframe.forge.plugin.data.mapper.DataConnectionMapper">

    <resultMap id="BaseResultMap" type="com.mdframe.forge.plugin.data.entity.DataConnection">
        <id column="id" property="id"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="connection_code" property="connectionCode"/>
        <result column="connection_name" property="connectionName"/>
        <result column="db_type" property="dbType"/>
        <result column="driver_class_name" property="driverClassName"/>
        <result column="jdbc_url" property="jdbcUrl"/>
        <result column="username" property="username"/>
        <result column="password_cipher" property="passwordCipher"/>
        <result column="schema_name" property="schemaName"/>
        <result column="test_sql" property="testSql"/>
        <result column="pool_config_json" property="poolConfigJson"/>
        <result column="status" property="status"/>
        <result column="description" property="description"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="create_dept" property="createDept"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectConnectionPage" resultMap="BaseResultMap">
        SELECT *
        FROM ai_report_data_connection
        WHERE tenant_id = #{tenantId}
        <if test="connectionName != null and connectionName != ''">
            AND connection_name LIKE CONCAT('%', #{connectionName}, '%')
        </if>
        <if test="dbType != null and dbType != ''">
            AND db_type = #{dbType}
        </if>
        <if test="status != null">
            AND status = #{status}
        </if>
        ORDER BY create_time DESC
    </select>

    <select id="selectConnectionList" resultMap="BaseResultMap">
        SELECT id, tenant_id, connection_code, connection_name, db_type, driver_class_name, 
               jdbc_url, username, schema_name, status, description
        FROM ai_report_data_connection
        WHERE tenant_id = #{tenantId}
          AND status = 1
        ORDER BY create_time DESC
    </select>

    <select id="selectConnectionByCode" resultMap="BaseResultMap">
        SELECT *
        FROM ai_report_data_connection
        WHERE connection_code = #{connectionCode}
          AND tenant_id = #{tenantId}
          AND status = 1
    </select>

    <select id="selectDatasetCountByConnectionId" resultType="int">
        SELECT COUNT(*)
        FROM ai_report_data_dataset
        WHERE connection_id = #{connectionId}
          AND tenant_id = #{tenantId}
    </select>

</mapper>
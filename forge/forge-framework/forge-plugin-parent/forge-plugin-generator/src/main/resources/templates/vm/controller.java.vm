package ${packageName}.${moduleName}.controller;

import com.baomidou.mybatisplus.extension.plugins.pagination.Page;
import ${packageName}.${moduleName}.dto.${className}DTO;
import ${packageName}.${moduleName}.dto.${className}Query;
import ${packageName}.${moduleName}.entity.${className};
import ${packageName}.${moduleName}.service.I${className}Service;
import com.mdframe.forge.starter.core.domain.PageQuery;
import com.mdframe.forge.starter.core.domain.RespInfo;
import com.mdframe.forge.starter.core.annotation.log.OperationLog;
import com.mdframe.forge.starter.core.domain.OperationType;
import lombok.RequiredArgsConstructor;
import org.springframework.web.bind.annotation.*;

import java.util.List;

/**
 * ${functionName}Controller
 *
 * @author ${author}
 * @date ${datetime}
 */
@RestController
@RequestMapping("/${moduleName}/${businessName}")
@RequiredArgsConstructor
public class ${className}Controller {

    private final I${className}Service ${classname}Service;

    /**
     * 分页查询${functionName}列表
     */
    @GetMapping("/page")
    @OperationLog(module = "${functionName}管理", type = OperationType.QUERY, desc = "分页查询${functionName}列表")
    public RespInfo<Page<${className}>> page(PageQuery pageQuery, ${className}Query query) {
        Page<${className}> page = ${classname}Service.select${className}Page(pageQuery, query);
        return RespInfo.success(page);
    }

    /**
     * 查询${functionName}列表
     */
    @GetMapping("/list")
    @OperationLog(module = "${functionName}管理", type = OperationType.QUERY, desc = "查询${functionName}列表")
    public RespInfo<List<${className}>> list(${className}Query query) {
        List<${className}> list = ${classname}Service.select${className}List(query);
        return RespInfo.success(list);
    }

    /**
     * 根据ID查询${functionName}详情
     */
    @PostMapping("/getById")
    public RespInfo<${className}> getById(@RequestParam Long ${pkColumn.javaField}) {
        ${className} ${classname} = ${classname}Service.select${className}ById(${pkColumn.javaField});
        return RespInfo.success(${classname});
    }

    /**
     * 新增${functionName}
     */
    @PostMapping("/add")
    @OperationLog(module = "${functionName}管理", type = OperationType.ADD, desc = "新增${functionName}")
    public RespInfo<Void> add(@RequestBody ${className}DTO dto) {
        boolean result = ${classname}Service.insert${className}(dto);
        return result ? RespInfo.success() : RespInfo.error("新增失败");
    }

    /**
     * 修改${functionName}
     */
    @PostMapping("/edit")
    @OperationLog(module = "${functionName}管理", type = OperationType.UPDATE, desc = "修改${functionName}")
    public RespInfo<Void> edit(@RequestBody ${className}DTO dto) {
        boolean result = ${classname}Service.update${className}(dto);
        return result ? RespInfo.success() : RespInfo.error("修改失败");
    }

    /**
     * 删除${functionName}
     */
    @PostMapping("/remove")
    @OperationLog(module = "${functionName}管理", type = OperationType.DELETE, desc = "删除${functionName}")
    public RespInfo<Void> remove(@RequestParam Long ${pkColumn.javaField}) {
        boolean result = ${classname}Service.delete${className}ById(${pkColumn.javaField});
        return result ? RespInfo.success() : RespInfo.error("删除失败");
    }

    /**
     * 批量删除${functionName}
     */
    @PostMapping("/removeBatch")
    @OperationLog(module = "${functionName}管理", type = OperationType.DELETE, desc = "批量删除${functionName}")
    public RespInfo<Void> removeBatch(@RequestBody Long[] ${pkColumn.javaField}s) {
        boolean result = ${classname}Service.delete${className}ByIds(${pkColumn.javaField}s);
        return result ? RespInfo.success() : RespInfo.error("批量删除失败");
    }
}

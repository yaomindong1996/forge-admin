package ${packageName}.${moduleName}.service.impl;

import cn.hutool.core.bean.BeanUtil;
import com.baomidou.mybatisplus.core.conditions.query.LambdaQueryWrapper;
import com.baomidou.mybatisplus.extension.plugins.pagination.Page;
import com.baomidou.mybatisplus.extension.service.impl.ServiceImpl;
import ${packageName}.${moduleName}.dto.${className}DTO;
import ${packageName}.${moduleName}.dto.${className}Query;
import ${packageName}.${moduleName}.entity.${className};
import ${packageName}.${moduleName}.mapper.${className}Mapper;
import ${packageName}.${moduleName}.service.I${className}Service;
import com.mdframe.forge.starter.core.domain.PageQuery;
import com.mdframe.forge.starter.trans.annotation.DictTranslate;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.apache.commons.lang3.StringUtils;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.util.Arrays;
import java.util.List;

/**
 * ${functionName}Service实现类
 * 
 * @author ${author}
 * @date ${datetime}
 */
@Service
@RequiredArgsConstructor
@Slf4j
public class ${className}ServiceImpl extends ServiceImpl<${className}Mapper, ${className}> implements I${className}Service {

    private final ${className}Mapper ${classname}Mapper;

    @Override
    @DictTranslate
    public Page<${className}> select${className}Page(PageQuery pageQuery, ${className}Query query) {
        log.info("分页查询参数:{}, 查询条件:{}", pageQuery, query);
        LambdaQueryWrapper<${className}> wrapper = buildQueryWrapper(query);
        return ${classname}Mapper.selectPage(pageQuery.toPage(), wrapper);
    }

    @Override
    @DictTranslate
    public List<${className}> select${className}List(${className}Query query) {
        log.info("查询参数:{}", query);
        LambdaQueryWrapper<${className}> wrapper = buildQueryWrapper(query);
        return ${classname}Mapper.selectList(wrapper);
    }

    @Override
    public ${className} select${className}ById(Long ${pkColumn.javaField}) {
        return ${classname}Mapper.selectById(${pkColumn.javaField});
    }

    @Override
    @Transactional(rollbackFor = Exception.class)
    public boolean insert${className}(${className}DTO dto) {
        ${className} ${classname} = new ${className}();
        BeanUtil.copyProperties(dto, ${classname});
        return ${classname}Mapper.insert(${classname}) > 0;
    }

    @Override
    @Transactional(rollbackFor = Exception.class)
    public boolean update${className}(${className}DTO dto) {
        ${className} ${classname} = new ${className}();
        BeanUtil.copyProperties(dto, ${classname});
        return ${classname}Mapper.updateById(${classname}) > 0;
    }

    @Override
    @Transactional(rollbackFor = Exception.class)
    public boolean delete${className}ById(Long ${pkColumn.javaField}) {
        return ${classname}Mapper.deleteById(${pkColumn.javaField}) > 0;
    }

    @Override
    @Transactional(rollbackFor = Exception.class)
    public boolean delete${className}ByIds(Long[] ${pkColumn.javaField}s) {
        return ${classname}Mapper.deleteBatchIds(Arrays.asList(${pkColumn.javaField}s)) > 0;
    }

    /**
     * 构建查询条件
     */
    private LambdaQueryWrapper<${className}> buildQueryWrapper(${className}Query query) {
        LambdaQueryWrapper<${className}> wrapper = new LambdaQueryWrapper<>();
#foreach($column in $columns)
#if($column.isQuery == 1)
#if($column.queryType == 'EQ')
        wrapper.eq(query.get${column.javaField.substring(0,1).toUpperCase()}${column.javaField.substring(1)}() != null, ${className}::get${column.javaField.substring(0,1).toUpperCase()}${column.javaField.substring(1)}, query.get${column.javaField.substring(0,1).toUpperCase()}${column.javaField.substring(1)}());
#elseif($column.queryType == 'LIKE')
        wrapper.like(StringUtils.isNotBlank(query.get${column.javaField.substring(0,1).toUpperCase()}${column.javaField.substring(1)}()), ${className}::get${column.javaField.substring(0,1).toUpperCase()}${column.javaField.substring(1)}, query.get${column.javaField.substring(0,1).toUpperCase()}${column.javaField.substring(1)}());
#end
#end
#end
        return wrapper;
    }
}

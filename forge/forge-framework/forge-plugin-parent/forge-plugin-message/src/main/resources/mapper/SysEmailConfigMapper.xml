<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mdframe.forge.plugin.message.mapper.SysEmailConfigMapper">

    <resultMap id="BaseResultMap" type="com.mdframe.forge.plugin.message.domain.entity.SysEmailConfig">
        <id column="id" property="id"/>
        <result column="config_id" property="configId"/>
        <result column="smtp_server" property="smtpServer"/>
        <result column="port" property="port"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="from_address" property="fromAddress"/>
        <result column="from_name" property="fromName"/>
        <result column="is_ssl" property="isSsl"/>
        <result column="is_auth" property="isAuth"/>
        <result column="retry_interval" property="retryInterval"/>
        <result column="max_retries" property="maxRetries"/>
        <result column="status" property="status"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="create_by" property="createBy"/>
        <result column="update_by" property="updateBy"/>
        <result column="remark" property="remark"/>
    </resultMap>

    <select id="selectEnabledConfig" resultMap="BaseResultMap">
        SELECT * FROM sys_email_config
        WHERE status = 1
        <if test="tenantId != null">
            AND tenant_id = #{tenantId}
        </if>
        LIMIT 1
    </select>

</mapper>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mdframe.forge.plugin.message.mapper.SysSmsConfigMapper">

    <resultMap id="BaseResultMap" type="com.mdframe.forge.plugin.message.domain.entity.SysSmsConfig">
        <id column="id" property="id"/>
        <result column="config_id" property="configId"/>
        <result column="supplier" property="supplier"/>
        <result column="access_key_id" property="accessKeyId"/>
        <result column="access_key_secret" property="accessKeySecret"/>
        <result column="signature" property="signature"/>
        <result column="template_id" property="templateId"/>
        <result column="weight" property="weight"/>
        <result column="retry_interval" property="retryInterval"/>
        <result column="max_retries" property="maxRetries"/>
        <result column="maximum" property="maximum"/>
        <result column="extra_config" property="extraConfig"/>
        <result column="daily_limit" property="dailyLimit"/>
        <result column="minute_limit" property="minuteLimit"/>
        <result column="status" property="status"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="create_by" property="createBy"/>
        <result column="update_by" property="updateBy"/>
        <result column="remark" property="remark"/>
    </resultMap>

    <select id="selectEnabledConfig" resultMap="BaseResultMap">
        SELECT * FROM sys_sms_config
        WHERE status = 1
        <if test="tenantId != null">
            AND tenant_id = #{tenantId}
        </if>
        ORDER BY weight DESC
        LIMIT 1
    </select>

</mapper>

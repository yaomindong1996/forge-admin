{
  "name": "forge-admin-opencode",
  "version": "1.0.0",
  "description": "Forge Admin OpenCode configuration",
  "commands": {
    "/spec:init": {
      "description": "初始化项目上下文",
      "steps": [
        "分析工程结构、依赖、分层模式，填充 rules/project-context.md"
      ]
    },
    "/propose": {
      "description": "创建变更提案（渐进式Spec流程）",
      "steps": [
        "创建changes/[变更名]目录",
        "复制spec.md/tasks.md/test-spec.md/log.md模板",
        "启动需求调研与澄清流程",
        "生成完整Spec并等待用户确认"
      ],
      "skill": "code-copilot-propose"
    },
    "/apply": {
      "description": "执行编码（按Spec实现）",
      "steps": [
        "校验Spec完整性与用户确认状态",
        "逐Task执行编码",
        "每个Task完成后自动Commit",
        "同步更新执行日志到log.md"
      ],
      "skill": "code-copilot-apply"
    },
    "/fix": {
      "description": "Review后修正迭代",
      "steps": [
        "同步更新Spec/Task文档",
        "增量修正代码",
        "更新执行日志",
        "重新提交审查"
      ],
      "skill": "code-copilot-fix"
    },
    "/review": {
      "description": "两阶段代码审查",
      "steps": [
        "阶段一：Spec合规性审查",
        "阶段二：代码质量审查",
        "生成审查报告",
        "标注需要修正的问题"
      ],
      "skill": "code-copilot-review"
    },
    "/test": {
      "description": "生成单测并执行",
      "steps": [
        "生成Test Spec",
        "按TDD模式实现单测",
        "执行测试并输出结果",
        "保障代码覆盖率达标"
      ],
      "skill": "code-copilot-test"
    },
    "/archive": {
      "description": "归档变更并沉淀知识",
      "steps": [
        "整理执行日志中的知识发现",
        "沉淀到knowledge/目录",
        "归档变更目录到历史归档区",
        "完成整个变更流程"
      ],
      "skill": "code-copilot-archive"
    }
  },
  "instructions": [
    ".opencode/instructions/code-rules.md",
    "code-copilot/rules/coding-style.md",
    "code-copilot/rules/domain-rules.md",
    "code-copilot/rules/security.md",
    "code-copilot/rules/project-context.md"
  ],
  "skills": [
    {
      "name": "code-copilot",
      "description": "Code Copilot 渐进式Spec开发流程",
      "path": "code-copilot/agents/copilot-prompt.md"
    },
    {
      "name": "spec-reviewer",
      "description": "Spec合规性审查专家",
      "path": "code-copilot/agents/spec-reviewer.md"
    },
    {
      "name": "code-quality-reviewer",
      "description": "代码质量审查专家",
      "path": "code-copilot/agents/code-quality-reviewer.md"
    }
  ]
}
